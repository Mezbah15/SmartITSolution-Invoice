            @* </div> *@
            <div class="participant-image ms-4">
                <img src="data:image/jpeg;base64,@Model" alt="Participant Image" class="rounded border" style="width: 150px; height: 150px; object-fit: cover;">
            </div>
        </div>
    </div>
