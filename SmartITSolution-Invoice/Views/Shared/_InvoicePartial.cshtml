@using SmartITSolution_Invoice.Models
@model InvoiceViewModel

#StartRegion
<style>
    body {
        font - family: 'Roboto', sans - serif;
    }

    .text-center {
        text-align: center;
    }

    .content {
        width: 210mm;
        padding: 10mm;
        border: 1px solid #ddd;
    }

    .admission - form {
        border: 1px solid #ddd;
        padding: 20px;
        margin: 20px 0;
        background - color: #f9f9f9;
    }

        .admission - form h3 {
            text-align: center;
            margin - bottom: 20px;
        }

        .admission - form p {
            font-size: 16px;
            margin: 5px 0;
        }

    .footer {
        margin-top: 20px;
        font - size: 14px;
        color: #555;
    }

        .footer p {
            margin: 5px 0;
        }

    .content {
        font-family: 'Roboto', sans - serif;
    }

    .d - flex {
        display: flex;
    }

    .justify - content - between {
        justify - content: space - between;
    }

    .align - items - start {
        align - items: flex - start;
    }

    .ms - 4 {
        margin - left: 1.5rem;
    }

    .rounded {
