<div class="content">
    <br />
    <br />
    <h2 class="text-center" > Smart IT Solution <br />
    Jigatola, Dhanmondhi, <br /> Dhaka, Bangladesh</h2 >
    <br /> <p > Phone: +8801309445401 <br /> www.smartitsolution.net</p >
    <div class="admission-form">
        <h3>Invoice</h3>
        <div class="d-flex justify-content-between align-items-start">
            <div class="form-details">
                <p><strong>Invoice Number:</strong> @Model.InvoiceNo</p>
                <p><strong>Date:</strong> @Model.Date.ToString("dd-MM-yyyy")</p>
                <p><strong>Client:</strong> @Model.CustomerDetails</p>
                @foreach(var m in @Model.Items){
                    <p><strong>পিতার নাম:</strong> </p>
                }
                <p > <strong > In Words:</strong > @Model.InWord </p >
                <p > <strong > Note If Any:</strong > @Model.Note </p >
            </div>
            @* <div class="participant-image ms-4"> *@
